{
  "editor.fontSize": 14,
  "editor.lineHeight": 1.7,
  "editor.letterSpacing": 0.2,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "phase",
  "editor.guides.indentation": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.renderWhitespace": "selection",
  "editor.renderLineHighlight": "gutter",
  "editor.scrollbar.vertical": "visible",
  "editor.scrollbar.horizontal": "visible",
  "editor.scrollbar.verticalScrollbarSize": 14,
  "editor.scrollbar.horizontalScrollbarSize": 14,
  "editor.minimap.enabled": true,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.maxColumn": 120,
  "editor.stickyScroll.enabled": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.decorations.badges": true,
  "workbench.editor.decorations.colors": true,
  "workbench.list.smoothScrolling": true,
  "workbench.tree.indent": 16,
  "breadcrumbs.enabled": true,
  "window.titleBarStyle": "custom",
  "workbench.colorCustomizations": {
    "tab.activeBackground": "#1f2937",
    "tab.activeForeground": "#f9fafb",
    "tab.activeBorderTop": "#f59e0b",
    "tab.activeModifiedBorder": "#34d399",
    "tab.inactiveBackground": "#111827",
    "tab.inactiveForeground": "#9ca3af",
    "tab.hoverBackground": "#243244",
    "editorLineNumber.activeForeground": "#f59e0b",
    "editor.lineHighlightBackground": "#0f172a",
    "editorIndentGuide.activeBackground1": "#475569",
    "editorIndentGuide.background1": "#334155",
    "scrollbarSlider.background": "#64748b66",
    "scrollbarSlider.hoverBackground": "#94a3b899",
    "scrollbarSlider.activeBackground": "#cbd5e1aa",
    "scrollbar.shadow": "#020617"
  }
}
